# Shared secrets
COWLY_AUTH_JWT_SECRET=dev-secret-change-in-production

# Collar simulator
COWLY_COLLAR_SIM_HERD_SIZE=100

# Postgres (host port 5433 maps to container 5432)
# Per-service DBs: cowly_auth, cowly_herd, cowly_collar, cowly_telemetry, cowly_alerts, cowly_notifications

# Local development (services outside Docker)
# COWLY_AUTH_DATABASE_URL=postgresql+psycopg2://cowly:cowly@localhost:5433/cowly_auth
# COWLY_HERD_DATABASE_URL=postgresql+psycopg2://cowly:cowly@localhost:5433/cowly_herd
