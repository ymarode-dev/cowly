# Copy to .env before first run:  cp .env.example .env
# Never commit .env — it contains secrets.

# Release / images
COWLY_VERSION=0.1.0
COWLY_IMAGE_REGISTRY=cowly
# COWLY_BUILD_TIMESTAMP=  # set automatically by scripts/setup.sh
# COWLY_VCS_REF=          # git short SHA, set by setup/build scripts

# Shared secrets
COWLY_AUTH_JWT_SECRET=dev-secret-change-in-production
COWLY_INTERNAL_API_KEY=cowly-internal-dev-key

# Gateway
COWLY_GATEWAY_PORT=8000
COWLY_GATEWAY_CORS_ORIGINS=*

# Service host ports (change if you have conflicts)
COWLY_AUTH_PORT=8102
COWLY_HERD_PORT=8103
COWLY_COLLAR_REGISTRY_PORT=8104
COWLY_SIMULATOR_PORT=8101
COWLY_TELEMETRY_PORT=8105
COWLY_ALERT_PORT=8106
COWLY_NOTIFICATION_PORT=8107
COWLY_POSTGRES_PORT=5433
COWLY_REDIS_PORT=6380

# Logging (info | debug)
COWLY_LOG_LEVEL=info

# Collar simulator
COWLY_COLLAR_SIM_HERD_SIZE=100

# Demo seed (make seed / ./scripts/setup.sh --seed)
COWLY_SEED_EMAIL=demo@cowly.local
COWLY_SEED_PASSWORD=demo-password-1
COWLY_SEED_FARM_NAME=Demo Farm

# Alert thresholds (telemetry auto-evaluation)
COWLY_ALERT_LOW_BATTERY_THRESHOLD=20
COWLY_ALERT_HIGH_TEMPERATURE_THRESHOLD=39.5
COWLY_ALERT_INACTIVITY_THRESHOLD=10

# Email notifications (enable with MailHog: docker run -p 1025:1025 mailhog/mailhog)
COWLY_NOTIFICATION_SMTP_ENABLED=false
COWLY_NOTIFICATION_SMTP_HOST=localhost
COWLY_NOTIFICATION_SMTP_PORT=1025
COWLY_NOTIFICATION_SMTP_FROM=cowly@localhost

# Local development (services outside Docker)
# COWLY_AUTH_DATABASE_URL=postgresql+psycopg2://cowly:cowly@localhost:5433/cowly_auth
# COWLY_HERD_DATABASE_URL=postgresql+psycopg2://cowly:cowly@localhost:5433/cowly_herd
